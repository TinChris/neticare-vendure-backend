# ============================================
# VENDURE WEBSHOP - COOLIFY ENVIRONMENT
# Copy this to .env and fill in the values
# ============================================

# ----------------------------------------
# DATABASE (PostgreSQL)
# ----------------------------------------
DB_NAME=vendure
DB_USERNAME=vendure
# Generate with: openssl rand -base64 32
DB_PASSWORD=CHANGE_ME_SECURE_PASSWORD

# Set to 'true' for FIRST deployment to create database schema
# After first successful start, change to 'false' and use migrations
DB_SYNC=true

# ----------------------------------------
# VENDURE SERVER
# ----------------------------------------
# Generate with: openssl rand -base64 32
COOKIE_SECRET=CHANGE_ME_RANDOM_STRING

# Admin credentials
SUPERADMIN_USERNAME=superadmin
# Choose a strong password!
SUPERADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ----------------------------------------
# PRODUCTION URLS
# ----------------------------------------
# URL where assets will be served from
ASSET_URL_PREFIX=https://shopadmin.neticare.at/assets/

# Primary storefront URL (for email links)
STOREFRONT_URL=https://shop1.neticare.at

# Storefront 1 (bearshop)
STOREFRONT1_URL=https://shop1.neticare.at

# Storefront 2 (neticare)
STOREFRONT2_URL=https://shop2.neticare.at

# ----------------------------------------
# CACHE REVALIDATION
# ----------------------------------------
# Generate with: openssl rand -base64 32
REVALIDATION_SECRET=CHANGE_ME_RANDOM_STRING

# Note: The .env file should be in the vendure-deploy root folder,
# NOT in my-vendure subfolder. Docker Compose reads it from root.

# ----------------------------------------
# EMAIL (Optional - for production emails)
# ----------------------------------------
EMAIL_FROM_ADDRESS="Vendure Shop" <noreply@neticare.at>

# SMTP settings (if using SMTP transport)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASSWORD=your-smtp-password
